{
  "name": "opabrow",
  "version": "0.3.0",
  "description": "opabrow - 透明浮层浏览器",
  "main": "./out/main/index.js",
  "author": "opabrow contributors",
  "license": "MPL-2.0",
  "private": false,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac:dir": "electron-vite build && electron-builder --mac --dir",
    "package:mac:arm64": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-vite build && electron-builder --mac dmg --arm64 --publish never",
    "package:mac:x64": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-vite build && electron-builder --mac dmg --x64 --publish never",
    "package:win:x64": "electron-vite build && electron-builder --win nsis --x64 --publish never",
    "package:linux:x64": "electron-vite build && electron-builder --linux AppImage --x64 --publish never",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run"
  },
  "dependencies": {
    "csv-parse": "^7.0.1",
    "lucide-react": "^1.25.0",
    "parse5": "^8.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
